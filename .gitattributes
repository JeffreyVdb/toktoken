# Force LF line endings for all text files
* text=auto eol=lf

# Ensure shell scripts are always LF
*.sh text eol=lf
*.bash text eol=lf

# Ensure source code is always LF
*.c text eol=lf
*.h text eol=lf
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cmake text eol=lf
*.txt text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.exe binary
